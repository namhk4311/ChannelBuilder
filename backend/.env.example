# Copy thành `.env` rồi điền giá trị thật. KHÔNG commit .env vào git.

# ─── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql://vng:vng@localhost:5433/vng_insider

# ─── MinIO ───────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9100
MINIO_ACCESS=minioadmin
MINIO_SECRET=minioadmin

# ─── ElevenLabs (TTS giọng đọc — Producer) ───────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_v3

# ─── VNGCloud MaaS — share cho Scout + Producer + Creative ───────────────────
AI_PLATFORM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
AI_PLATFORM_API_KEY=
AI_PLATFORM_MODEL=deepseek/deepseek-v4-flash
CREATIVE_MODEL=minimax/minimax-m2.5
# Scout dùng model riêng (tách khỏi CREATIVE_MODEL — có thể đổi độc lập sau này)
SCOUT_MODEL=minimax/minimax-m2.5
# true: Scout LLM extract trang TikTok thật (metric=likes) | false: chỉ dataset seed (đỡ quota)
SCOUT_USE_LLM=true

# ─── TikTok API — Publisher ──────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=
TIKTOK_SCOPES=user.info.basic,video.publish

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_FILE=logs/app.log
