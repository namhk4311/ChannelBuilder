# Copy thành `.env` rồi điền giá trị thật. KHÔNG commit .env vào git.

# ─── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql://vng:vng@localhost:5433/vng_insider

# ─── MinIO ───────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9100
MINIO_ACCESS=minioadmin
MINIO_SECRET=minioadmin

# ─── ElevenLabs (TTS giọng đọc — Producer) ───────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
# wBXNqKUATyqu0RtYt25i
ELEVENLABS_MODEL_ID=eleven_v3

# ─── VNGCloud MaaS — share cho Scout + Producer + Creative ───────────────────
AI_PLATFORM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
AI_PLATFORM_API_KEY=
AI_PLATFORM_MODEL=deepseek/deepseek-v4-flash
CREATIVE_MODEL=minimax/minimax-m2.5
# Scout dùng model riêng (tách khỏi CREATIVE_MODEL — có thể đổi độc lập sau này)
SCOUT_MODEL=minimax/minimax-m2.5
# true: Scout LLM extract trang TikTok thật (metric=likes) | false: chỉ dataset seed (đỡ quota)
SCOUT_USE_LLM=true
# QC kịch bản: true (default) bật thêm lớp LLM judge (hook/mạch/khớp-ý, dùng CREATIVE_MODEL);
# false = chỉ deterministic (clip/coverage/cụt) — đỡ quota lúc dev. Deterministic LUÔN chạy.
CREATIVE_QC_USE_LLM=true
# Số lần tối đa cho Creative viết lại theo feedback QC (auto self-correct / human bấm "viết lại").
# Chặn vòng lặp đốt quota. 0 = không bao giờ viết lại.
CREATIVE_QC_MAX_RETRIES=2
# Model riêng cho LLM judge của QC (để model CHẤM khác model VIẾT → second opinion độc lập).
# Default = CREATIVE_MODEL. Khuyến nghị instruct non-thinking ổn định (minimax/minimax-m2.5,
# hoặc qwen*-instruct nếu MaaS có). Tránh model reasoning/thinking (chậm + dễ rỗng).
CREATIVE_QC_MODEL=minimax/minimax-m2.5

# ─── TikTok API — Publisher ──────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=
TIKTOK_SCOPES=user.info.basic,video.publish

# ─── Publisher scheduler (đăng theo lịch + guardrail bài/ngày) ───────────────
# Guardrail tự đặt chống spam (KHÔNG phải trần TikTok). 5 = bảo thủ cho kênh non.
MAX_POSTS_PER_DAY=5
SCHEDULE_TZ=Asia/Saigon
# Chu kỳ poller quét queue (giây) — đăng bài đúng giờ riêng từng bài.
SCHEDULE_TICK_SECONDS=60
# Giờ pre-fill sẵn cho datetime picker trên UI (user đè được).
SCHEDULE_DEFAULT_HOUR=9
# false để tắt poller (vd khi scale nhiều replica, chỉ bật ở 1 instance).
SCHEDULE_TICK_ENABLED=true

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_FILE=logs/app.log
